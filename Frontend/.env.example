# Backend API base URL
VITE_API_URL=http://localhost:5000/api/v1

# Google Maps JavaScript API key (used by the Public Portal live map).
# Get one at https://console.cloud.google.com/google/maps-apis
# Enable: "Maps JavaScript API" (and "Places API" if you plan to use search suggestions).
# Restrict the key to your dev/prod domains once you're ready to ship.
VITE_GOOGLE_MAPS_API_KEY=
